kcm() {
  if [[ "$1" == "prod" || "$1" == "testing" || "$1" == "dev" || "$1" == "stage" || "$1" == "china" ]]; then
    role=""
    if [[ "$1" == "china" ]]; then
      role="norole"
    fi
    echo "Logging into $1 CMVPN EKS Cluster"
    pushd "$HOME/projects/stl/cmvpn-terafform/live/$1/eks/" || return
    # shellcheck source=/dev/null
    source ./auth.sh "$role"
    popd || return
  else
    echo "pass in one of: prod|testing|stage|dev"
  fi
}

