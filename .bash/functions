# --- Utilities ---

uuid() {
  uuidgen | tr -d '\n' | tr '[:upper:]' '[:lower:]'
}

uuidcopy() {
  id=$(uuid)
  echo -n "$id" | pbcopy
  echo -n "$id Copied"
}

rand() {
  LENGTH=$1

  if [[ -z "$LENGTH" || ! "$LENGTH" =~ ^[0-9]+$ ]]; then
    echo "Usage: $0 <length>"
    exit 1
  fi
  openssl rand -base64 $((LENGTH * 3 / 4)) | tr -dc 'A-Za-z0-9' | head -c "$LENGTH"
}

randcopy() {
  r=$(rand "$1")
  echo -n "$r" | pbcopy
  echo -n "$r Copied"
}

# --- Git ---

gc() {
  local TMP_FILE BRANCH STAT DIFF PROMPT EDITOR_CMD
  TMP_FILE="$(mktemp)"

  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  STAT=$(git diff --cached --stat | grep -v vendor)
  DIFF=$(git diff --cached | grep -v vendor | head -c 50000)

  if [[ -z "$STAT" ]]; then
    echo "No staged changes found. Use git add to stage changes first."
    rm "$TMP_FILE"
    return 1
  fi

  PROMPT="Generate a commit message for these file changes.

Branch: $BRANCH

Staged files:
$STAT

Diff:
$DIFF

Instructions:
- Start with a summary in imperative mood.
- Explain the why behind changes, when possible. Don't make anything up.
- If changes are small try and keep it to a single line, only add multiple points if not possible to summarize.
- Use bullet points for multiple changes, except when the why is attached to item.
- Try to get the Ticket Number from the branch name in the form of Project-Number, i.e VPN-1234.
- If you can't get ticket number then omit it.
- Do not wrap your response in triple backticks.
- Response should be the commit message only, no explanations as it will be passed directly to git.
- The body and footer are truly optional and prefer to not have them if possible.
- Format: <Ticket Number> <Action> <Subject>

    [optional body]

    [optional footer(s)]"

  claude --model us.anthropic.claude-haiku-4-5-20251001-v1:0 -p "$PROMPT" >"$TMP_FILE"

  EDITOR_CMD="${GIT_EDITOR:-${EDITOR:-nvim}}"
  GIT_EDITOR="$EDITOR_CMD" git commit --edit -F "$TMP_FILE"

  rm "$TMP_FILE"
}

# --- Sandbox ---

sandbox-claude() { ~/.config/sandbox-exec/run-sandboxed.sh claude "$@"; }
sandbox-codex()  { ~/.config/sandbox-exec/run-sandboxed.sh codex "$@"; }

msb-sandbox() {
  local repo
  local name
  repo="$(pwd)"
  name=$(basename "$repo")

  msb run --name "$name" -c 4 -m 8G \
    -v "$repo":"/${name}" \
    -v claude-data:/data/claude \
    -w "/${name}" \
    -e CLAUDE_CODE_USE_BEDROCK \
    --replace \
    --secret AWS_BEARER_TOKEN_BEDROCK="$AWS_BEARER_TOKEN_BEDROCK"@api.anthropic.com \
    docker.local.hsdp.io/claude:local "$@"
}
